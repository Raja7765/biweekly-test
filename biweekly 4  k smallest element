import java.util.*;

public class Main {
    public static int solve(int[] nums, int k) {
        PriorityQueue<Integer> minHeap = new PriorityQueue<>();
        for (int n : nums) {
            minHeap.add(n);
            if (minHeap.size() > k) {
                minHeap.poll();
            }
        }
        return minHeap.peek();
    }

    public static void main(String[] args) {
        int[] arr = {3, 7, 2, 5, 6};
        int k = 2;
        System.out.println(solve(arr, k));
    }
}
